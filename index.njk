    <!-- ============================================================
         SECTIE 6 — CONTACTFORMULIER
         ============================================================ -->
    <section id="contact-form" class="contact-form-section" aria-labelledby="contact-form-titel">
      <div class="container contact-form-section__inner">

        <div class="contact-form-section__header">
          <span class="section-label reveal-fade">Formulier</span>
          <h2 class="section-title" id="contact-form-titel">Neem contact op</h2>
        </div>

        <form
          class="contact__form reveal-scale"
          name="contact"
          method="POST"
          action="/dank-je.html"
          data-netlify="true"
          netlify-honeypot="bot-field"
          aria-label="Contactformulier"
        >
          <p hidden>
            <label>Niet invullen: <input name="bot-field"></label>
          </p>

          <div class="form-field">
            <label for="naam">Naam</label>
            <input
              type="text"
              id="naam"
              name="naam"
              autocomplete="name"
              placeholder="Sam Altman"
              required
              aria-required="true"
            >
          </div>

          <div class="form-field">
            <label for="email">E-mailadres</label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              placeholder="sam@altman.nl"
              required
              aria-required="true"
            >
          </div>

          <div class="form-field">
            <label for="bericht">Bericht</label>
            <textarea
              id="bericht"
              name="bericht"
              rows="5"
              placeholder="Vertel kort wat je nodig hebt. Een paar zinnen is genoeg."
              required
              aria-required="true"
            ></textarea>
          </div>

          <button type="submit" class="btn btn--primary">Versturen</button>

        </form>

      </div>
    </section>
