<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Google Analytics 4 — laadt alleen na cookietoestemming -->
  <script>if(localStorage.getItem('byggr-cookies')){var s=document.createElement('script');s.async=true;s.src='https://www.googletagmanager.com/gtag/js?id=G-KTDQMECGQJ';document.head.appendChild(s);window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}window.gtag=gtag;gtag('js',new Date());gtag('config','G-KTDQMECGQJ');}</script>

  <meta name="description" content="{{ metaDescription }}">
  {% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
  <title>{{ pageTitle }}</title>
  <link rel="canonical" href="{{ canonical }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ ogTitle if ogTitle else pageTitle }}">
  <meta property="og:description" content="{{ ogDescription if ogDescription else metaDescription }}">
  <meta property="og:image" content="{{ ogImage }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:url" content="{{ canonical }}">
  <meta property="og:type" content="{{ ogType if ogType else 'website' }}">
  <meta property="og:locale" content="nl_NL">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ ogTitle if ogTitle else pageTitle }}">
  <meta name="twitter:description" content="{{ ogDescription if ogDescription else metaDescription }}">
  <meta name="twitter:image" content="{{ ogImage }}">

  {% if structuredData %}
  <script type="application/ld+json">
  {{ structuredData | safe }}
  </script>
  {% endif %}

  <!-- Theme: direct toepassen om flash te voorkomen -->
  <script>if(localStorage.getItem('byggr-theme')==='dark')document.documentElement.setAttribute('data-theme','dark');</script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32">

  <!-- Fonts: Bebas Neue + Barlow Condensed + Space Mono + Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@600;700&family=Space+Mono:wght@400;700&family=Inter:wght@400;500&display=swap" rel="stylesheet">

  <!-- CSS: gemeenschappelijk -->
  <link rel="stylesheet" href="/src/css/reset.css">
  <link rel="stylesheet" href="/src/css/tokens.css">
  <link rel="stylesheet" href="/src/css/base.css">
  <link rel="stylesheet" href="/src/css/sections/nav.css">
  <link rel="stylesheet" href="/src/css/sections/footer.css">

  <!-- CSS: pagina-specifiek -->
  {% if extraCSS %}
    {% for css in extraCSS %}
  <link rel="stylesheet" href="{{ css }}">
    {% endfor %}
  {% endif %}

  {% if inlineCSS %}
  <style>{{ inlineCSS | safe }}</style>
  {% endif %}
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>

  <a href="#main-content" class="skip-link">Ga naar inhoud</a>

  <!-- ============================================================
       NAVIGATIE
       ============================================================ -->
  <header role="banner">
    <nav class="nav" aria-label="Hoofdnavigatie">
      <div class="container nav__inner">

        {% if isHome %}
        <a href="#" class="nav__logo" aria-label="BYGGR — naar boven">
        {% else %}
        <a href="/" class="nav__logo" aria-label="BYGGR — naar homepage">
        {% endif %}
          <img src="/logo-light.svg" alt="BYGGR" class="nav__logo-img nav__logo-img--light" width="120" height="29">
          <img src="/logo-dark.svg"  alt="BYGGR" class="nav__logo-img nav__logo-img--dark"  width="120" height="29">
        </a>

        {% if not simpleNav %}
        <ul class="nav__links" role="list">
          {% if isHome %}
          <li><a href="#services" class="nav__link">Services</a></li>
          <li><a href="#over" class="nav__link">Over</a></li>
          <li><a href="#portfolio" class="nav__link">Portfolio</a></li>
          <li><a href="#contact" class="nav__link">Contact</a></li>
          {% else %}
          <li><a href="/#services" class="nav__link">Services</a></li>
          <li><a href="/#over" class="nav__link">Over</a></li>
          <li><a href="/#portfolio" class="nav__link">Portfolio</a></li>
          <li><a href="/#contact" class="nav__link">Contact</a></li>
          {% endif %}
        </ul>
        {% endif %}

        <div class="nav__actions">
          <button class="nav__theme-toggle" id="theme-toggle" aria-label="Wisselen naar donker thema">◐</button>
          {% if not simpleNav %}
          <button
            class="nav__hamburger"
            aria-label="Menu openen"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </button>
          {% endif %}
        </div>

      </div>
    </nav>

    {% if not simpleNav %}
    <div id="mobile-menu" class="nav__mobile-menu" role="dialog" aria-label="Navigatiemenu" aria-modal="true">
      <ul role="list">
        {% if isHome %}
        <li><a href="#services" class="nav__mobile-link">Services</a></li>
        <li><a href="#over" class="nav__mobile-link">Over</a></li>
        <li><a href="#portfolio" class="nav__mobile-link">Portfolio</a></li>
        <li><a href="#contact" class="nav__mobile-link">Contact</a></li>
        {% else %}
        <li><a href="/#services" class="nav__mobile-link">Services</a></li>
        <li><a href="/#over" class="nav__mobile-link">Over</a></li>
        <li><a href="/#portfolio" class="nav__mobile-link">Portfolio</a></li>
        <li><a href="/#contact" class="nav__mobile-link">Contact</a></li>
        {% endif %}
      </ul>
    </div>
    {% endif %}
  </header>

  <main id="main-content">
    {{ content | safe }}
  </main>

  <!-- ============================================================
       FOOTER
       ============================================================ -->
  <footer class="footer" role="contentinfo">
    <div class="container footer__inner">

      <span class="footer__logo">
        <img src="/logo-light.svg" alt="BYGGR" class="footer__logo-img footer__logo-img--light" width="100" height="24">
        <img src="/logo-dark.svg"  alt="BYGGR" class="footer__logo-img footer__logo-img--dark"  width="100" height="24">
      </span>

      <nav class="footer__nav" aria-label="Footer navigatie">
        {% if isHome %}
        <a href="#services">Services</a>
        <a href="#over">Over</a>
        <a href="#portfolio">Portfolio</a>
        <a href="#contact">Contact</a>
        {% else %}
        <a href="/#services">Services</a>
        <a href="/#over">Over</a>
        <a href="/#portfolio">Portfolio</a>
        <a href="/#contact">Contact</a>
        {% endif %}
        <a href="/privacy.html">Privacy</a>
      </nav>

      <p class="footer__copy">
        &copy; <span id="current-year">2026</span> BYGGR — Remco Baumeister, Delden
      </p>

    </div>
  </footer>

  <!-- Cookie banner -->
  <div id="cookie-banner" class="cookie-banner" role="alertdialog" aria-label="Cookiemelding" hidden>
    <p>Deze site gebruikt analytics om bezoekersgedrag bij te houden. <a href="/privacy.html">Meer info</a></p>
    <button id="cookie-accept" class="cookie-banner__btn">Akkoord</button>
  </div>

  {% if includeNetlifyIdentity %}
  <!-- Netlify Identity — redirect naar /admin/ na login -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on('init', function(user) {
        if (!user) {
          window.netlifyIdentity.on('login', function() {
            document.location.href = '/admin/';
          });
        }
      });
    }
  </script>
  {% endif %}

  <!-- JavaScript -->
  <script src="/src/js/main.js" defer></script>
  <script src="/src/js/animations.js" defer></script>
  <script>document.getElementById('current-year').textContent = new Date().getFullYear();</script>
  <script>
    // Cookie consent + GA4 activeren na akkoord
    (function() {
      function loadGA() {
        if (window._gaLoaded) return;
        window._gaLoaded = true;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-KTDQMECGQJ';
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', 'G-KTDQMECGQJ');
      }
      if (localStorage.getItem('byggr-cookies')) {
        loadGA();
      } else {
        var banner = document.getElementById('cookie-banner');
        if (banner) banner.removeAttribute('hidden');
      }
      var btn = document.getElementById('cookie-accept');
      if (btn) btn.addEventListener('click', function() {
        localStorage.setItem('byggr-cookies', '1');
        var banner = document.getElementById('cookie-banner');
        if (banner) banner.setAttribute('hidden', '');
        loadGA();
      });
    })();
  </script>

</body>
</html>
